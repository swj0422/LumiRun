# LumiRun 逐光成长系统 - 环境变量配置

# 应用配置
APP_NAME=LumiRun
APP_NAME_CN=逐光成长系统
DEBUG=true
VERSION=1.0.0

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=mysql+aiomysql://lumirun:lumirunpassword@localhost:3306/lumirun?charset=utf8mb4
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 缓存配置
CACHE_EXPIRE_SECONDS=300

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/lumirun.log

# 第三方集成配置（后期扩展）
WEWORK_CORP_ID=
WEWORK_SECRET=
WEWORK_AGENT_ID=
